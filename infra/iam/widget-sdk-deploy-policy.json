{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WidgetSdkBucketWrite",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectAcl",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::automatos-widget-sdk",
        "arn:aws:s3:::automatos-widget-sdk/*"
      ]
    },
    {
      "Sid": "WidgetSdkInvalidateOnly",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation",
        "cloudfront:ListInvalidations"
      ],
      "Resource": "arn:aws:cloudfront::REPLACE_ACCOUNT_ID:distribution/REPLACE_DISTRIBUTION_ID"
    }
  ]
}
